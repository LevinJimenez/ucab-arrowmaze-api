PORT=3000
# Supabase: Transaction Pooler (puerto 6543) para runtime
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Supabase: Direct Connection (puerto 5432) para migraciones
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
# Local (desarrollo sin Supabase):
# DATABASE_URL=postgresql://user:password@localhost:5432/arrowmaze
# DIRECT_URL=postgresql://user:password@localhost:5432/arrowmaze
JWT_SECRET=your-secret-key-change-in-production-minimum-16-chars
JWT_EXPIRES_IN=30d
NODE_ENV=development
# IA — generación de niveles (Fase D · Feature 2). Sin key, POST /levels/generate
# responde 502 (LevelGenerationError) en vez de fallar al arrancar.
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-5
LLM_TIMEOUT_MS=120000
# Opcional (low|medium|high): baja latencia y evita sobre-razonamiento en
# modelos con thinking adaptativo (sonnet-5, opus 4.x). Dejar vacio con Haiku.
LLM_EFFORT=low
