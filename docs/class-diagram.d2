# =============================================================
#  Arrow Maze - Backend · Diagrama de CLASES (Clean Architecture + DDD tactico)
#
#  Estructura vertical:  C4 (arriba) -> C3 -> C2 -> C1 (abajo).
#  Todas las flechas apuntan hacia ABAJO = hacia adentro (regla de dependencia).
#
#  Notacion UML:
#    diamante lleno                = composicion (el agregado POSEE sus Value Objects)
#    triangulo hueco + punteada    = realizacion (implements de un puerto)
#    triangulo hueco + linea llena = herencia (extends)
#    flecha punteada               = dependencia (usa)
#    +  publico     -  privado
#
#  Se dibujan TODAS las relaciones estructurales del codigo, sin excepciones:
#    · realizacion (implements) y herencia (extends)
#    · composicion: el agregado -> CADA UNO de sus Value Objects
#    · dependencia por inyeccion: caso de uso -> puerto (DIP), controller -> caso de uso
#      y -> puerto, decorator -> ILogger
#    · uso intra-C4: repo -> Prisma, adapter -> SDK  (NO viola la regla de dependencia:
#      los repositorios concretos viven en C4, junto a Prisma)
#    · "lanza": quien dispara cada DomainError
#  Ninguna clase queda aislada y ninguna dependencia estructural queda implicita.
#
#  Cobertura: incluye Fase D — modo Supervivencia (SurvivalEntry) y generacion de
#  niveles con IA (ILevelGenerator). Ninguna clase queda aislada.
#
#  Render:  d2 --theme 0 --layout elk docs/class-diagram.d2 docs/class-diagram.svg
# =============================================================

direction: down

# =============================================================
#  CAPA 4 · FRAMEWORKS & DRIVERS
# =============================================================
capa4: "CAPA 4 · Frameworks & Drivers" {
  style: { fill: "#F9FAFB"; stroke: "#6B7280"; font-size: 24; bold: true }

  services: "Concrete Services" {
    style: { fill: "#F3F4F6"; stroke: "#4B5563" }

    Bcrypt: "BcryptPasswordService   <<Adapter>>" {
      shape: class
      "-saltRounds": number
      "+hash(password)": "Promise<string>"
      "+verify(password, hash)": "Promise<boolean>"
    }
    Uuid: "UuidIdGenerator   <<Adapter>>" {
      shape: class
      "+generate()": string
    }
    AuthFacade: "AuthFacade   <<Facade>>" {
      shape: class
      "+generateToken(userId, username)": string
      "+verifyToken(token)": TokenPayload
    }
    ConsoleLogger: "ConsoleLogger   <<Adapter>>" {
      shape: class
      "+info(msg, meta)": void
      "+warn(msg, meta)": void
      "+error(msg, meta)": void
      "+debug(msg, meta)": void
    }
    LlmLevelGenerator: "LlmLevelGenerator   <<Adapter>>" {
      shape: class
      "-client": "Anthropic?  (perezoso)"
      "+generate(spec)": "Promise<LevelData>"
    }
  }

  strategies: "Leaderboard Strategies" {
    style: { fill: "#EDE9FE"; stroke: "#6D28D9" }

    PerLevel: "PerLevelLeaderboardStrategy   <<Strategy>>" {
      shape: class
      "+calculateRanking(entries, limit)": "LeaderboardEntry[]"
    }
    TotalScore: "TotalScoreLeaderboardStrategy   <<Strategy>>" {
      shape: class
      "+calculateRanking(entries, limit)": "LeaderboardEntry[]"
    }
    Combined: "CombinedLeaderboardStrategy   <<Strategy>>" {
      shape: class
      "-scoreWeight": number
      "-efficiencyWeight": number
      "+calculateRanking(entries, limit)": "LeaderboardEntry[]"
    }
  }

  decorators: "AOP Decorators" {
    style: { fill: "#E0E7FF"; stroke: "#4338CA" }

    LogDec: "LoggingUseCaseDecorator   <<Decorator>>" {
      shape: class
      "-inner": "IUseCase<I,O>"
      "-logger": ILogger
      "-useCaseName": string
      "+execute(input)": "Promise<O>"
    }
    ExcDec: "ExceptionHandlingUseCaseDecorator   <<Decorator>>" {
      shape: class
      "-inner": "IUseCase<I,O>"
      "-logger": ILogger
      "-useCaseName": string
      "+execute(input)": "Promise<O>"
    }
    CacheDec: "CachingUseCaseDecorator   <<Decorator>>" {
      shape: class
      "-inner": "IUseCase<I,O>"
      "-ttlMs": number
      "-keyFor": "(input) => string"
      "-logger": ILogger
      "+execute(input)": "Promise<O>"
    }
  }

  persistence: "Persistence" {
    style: { fill: "#E5E7EB"; stroke: "#374151" }

    Prisma: "PrismaClient   <<ORM>>" {
      shape: class
      "+user / playerProgress": delegates
      "+level / leaderboardEntry": delegates
      "+survivalEntry": delegates
    }
  }

  llm: "LLM Driver" {
    style: { fill: "#E5E7EB"; stroke: "#374151" }

    Anthropic: "Anthropic   <<SDK>>" {
      shape: class
      "+messages.parse(params, opts)": "Promise<Message>"
    }
  }

  repositories: "Repository Adapters (implementan los puertos de C1 · usan Prisma)" {
    style: { fill: "#E5E7EB"; stroke: "#15803D" }

    PostgresUserRepository: "PostgresUserRepository   <<Adapter>>" {
      shape: class
      "-prisma": PrismaClient
      "+findById(id)": "Promise<User | null>"
      "+findByEmail(email)": "Promise<User | null>"
      "+findByUsername(username)": "Promise<User | null>"
      "+create(user)": "Promise<User>"
      "+update(user)": "Promise<User>"
    }
    PostgresProgressRepository: "PostgresProgressRepository   <<Adapter>>" {
      shape: class
      "-prisma": PrismaClient
      "+getByUserId(userId)": "Promise<PlayerProgress | null>"
      "+save(progress)": "Promise<PlayerProgress>"
    }
    PostgresLeaderboardRepository: "PostgresLeaderboardRepository   <<Adapter>>" {
      shape: class
      "-prisma": PrismaClient
      "+addEntry(entry)": "Promise<LeaderboardEntry>"
      "+getByLevel(levelId, limit)": "Promise<LeaderboardEntry[]>"
    }
    PostgresLevelDefinitionRepository: "PostgresLevelDefinitionRepository   <<Adapter>>" {
      shape: class
      "-prisma": PrismaClient
      "+getAll()": "Promise<LevelDefinition[]>"
      "+getById(id)": "Promise<LevelDefinition | null>"
      "+save(level)": "Promise<LevelDefinition>"
    }
    PostgresSurvivalRepository: "PostgresSurvivalRepository   <<Adapter>>" {
      shape: class
      "-prisma": PrismaClient
      "+addEntry(entry)": "Promise<SurvivalEntry>"
      "+getTop(durationSeconds, limit)": "Promise<SurvivalEntry[]>"
    }
  }
}

# =============================================================
#  CAPA 3 · INTERFACE ADAPTERS
# =============================================================
capa3: "CAPA 3 · Interface Adapters" {
  style: { fill: "#F0FDF4"; stroke: "#16A34A"; font-size: 24; bold: true }

  controllers: "HTTP Controllers" {
    style: { fill: "#D1FAE5"; stroke: "#047857" }

    AuthController: "AuthController   <<Controller>>" {
      shape: class
      "-registerUseCase": IUseCase
      "-authenticateUseCase": IUseCase
      "-tokenService": ITokenService
      "+register(req, res)": "Promise<void>"
      "+login(req, res)": "Promise<void>"
    }
    ProgressController: "ProgressController   <<Controller>>" {
      shape: class
      "-syncProgressUseCase": IUseCase
      "-progressRepository": IProgressRepository
      "+getProgress(req, res)": "Promise<void>"
      "+syncProgress(req, res)": "Promise<void>"
    }
    LeaderboardController: "LeaderboardController   <<Controller>>" {
      shape: class
      "-getLeaderboardUseCase": IUseCase
      "+getLeaderboard(req, res)": "Promise<void>"
    }
    LevelController: "LevelController   <<Controller>>" {
      shape: class
      "-getLevelDefinitionsUseCase": IUseCase
      "-getLevelByIdUseCase": IUseCase
      "-upsertLevelDefinitionUseCase": IUseCase
      "-generateLevelUseCase": IUseCase
      "+getAll(req, res)": "Promise<void>"
      "+getById(req, res)": "Promise<void>"
      "+upsert(req, res)": "Promise<void>"
      "+generate(req, res)": "Promise<void>"
    }
    SurvivalController: "SurvivalController   <<Controller>>" {
      shape: class
      "-submitSurvivalRunUseCase": IUseCase
      "-getSurvivalLeaderboardUseCase": IUseCase
      "+submit(req, res)": "Promise<void>"
      "+getLeaderboard(req, res)": "Promise<void>"
    }
  }

  mappers: "Mappers" {
    style: { fill: "#ECFDF5"; stroke: "#059669" }

    LevelMapper: "LevelMapper   <<Mapper>>" {
      shape: class
      "+toDto(level)": LevelDto
    }
    ProgressMapper: "ProgressMapper   <<Mapper>>" {
      shape: class
      "+toDto(progress)": ProgressDto
    }
    LeaderboardMapper: "LeaderboardMapper   <<Mapper>>" {
      shape: class
      "+toDto(entry)": LeaderboardEntryDto
    }
    SurvivalMapper: "SurvivalMapper   <<Mapper>>" {
      shape: class
      "+toDto(entry)": SurvivalEntryDto
    }
  }

  factory: "Factory" {
    style: { fill: "#DCFCE7"; stroke: "#047857" }

    ResponseFactory: "ResponseFactory   <<Factory Method>>" {
      shape: class
      "+success(res, data, status)": void
      "+created(res, data)": void
      "+error(res, message, status)": void
      "+paginated(res, data, total, page, limit)": void
    }
  }

  dtos: "DTOs" {
    style: { fill: "#F0FDF4"; stroke: "#16A34A"; stroke-dash: 2 }

    LevelDto: "LevelDto   <<DTO>>" {
      shape: class
      "+id": string
      "+name": string
      "+difficulty": string
      "+parMoves": "number?"
      "+data": LevelDataProps
    }
    ProgressDto: "ProgressDto   <<DTO>>" {
      shape: class
      "+userId": string
      "+completedLevels": "string[]"
      "+bestScores": "Record<string, number>"
      "+currentLevelId": string
    }
    LeaderboardEntryDto: "LeaderboardEntryDto   <<DTO>>" {
      shape: class
      "+userId / username": string
      "+levelId": string
      "+score / moves / timeSeconds": number
      "+rankedAt": string
    }
    SurvivalEntryDto: "SurvivalEntryDto   <<DTO>>" {
      shape: class
      "+userId / username": string
      "+boardsSolved": number
      "+durationSeconds": number
      "+totalScore": "number?"
      "+playedAt": string
    }
    ApiResponse: "ApiResponse<T>   <<DTO>>" {
      shape: class
      "+success": boolean
      "+data": "T?"
      "+message": "string?"
      "+meta": "{ total, page, limit }?"
    }
  }
}

# =============================================================
#  CAPA 2 · USE CASES & PUERTOS TECNICOS
# =============================================================
capa2: "CAPA 2 · Use Cases" {
  style: { fill: "#EFF6FF"; stroke: "#2563EB"; font-size: 24; bold: true }

  uc: "Use Cases" {
    style: { fill: "#DBEAFE"; stroke: "#1D4ED8" }

    RegisterUserUseCase: "RegisterUserUseCase   <<Use Case>>" {
      shape: class
      "-userRepository": IUserRepository
      "-passwordHasher": IPasswordHasher
      "-idGenerator": IIdGenerator
      "+execute(input)": "Promise<RegisterUserOutput>"
    }
    AuthenticateUserUseCase: "AuthenticateUserUseCase   <<Use Case>>" {
      shape: class
      "-userRepository": IUserRepository
      "-passwordVerifier": IPasswordVerifier
      "+execute(input)": "Promise<AuthenticateUserOutput>"
    }
    SyncProgressUseCase: "SyncProgressUseCase   <<Use Case>>" {
      shape: class
      "-progressRepository": IProgressRepository
      "-leaderboardRepository": ILeaderboardRepository
      "+execute(input)": "Promise<PlayerProgress>"
    }
    GetLeaderboardUseCase: "GetLeaderboardUseCase   <<Use Case>>" {
      shape: class
      "-leaderboardRepository": ILeaderboardRepository
      "-leaderboardStrategy": ILeaderboardStrategy
      "+execute(input)": "Promise<LeaderboardEntry[]>"
    }
    GetLevelDefinitionsUseCase: "GetLevelDefinitionsUseCase   <<Use Case>>" {
      shape: class
      "-levelDefinitionRepository": ILevelDefinitionRepository
      "+execute()": "Promise<LevelDefinition[]>"
    }
    GetLevelByIdUseCase: "GetLevelByIdUseCase   <<Use Case>>" {
      shape: class
      "-levelDefinitionRepository": ILevelDefinitionRepository
      "+execute(id)": "Promise<LevelDefinition | null>"
    }
    UpsertLevelDefinitionUseCase: "UpsertLevelDefinitionUseCase   <<Use Case>>" {
      shape: class
      "-levelDefinitionRepository": ILevelDefinitionRepository
      "+execute(input)": "Promise<LevelDefinition>"
    }
    SubmitSurvivalRunUseCase: "SubmitSurvivalRunUseCase   <<Use Case>>" {
      shape: class
      "-survivalRepository": ISurvivalRepository
      "+execute(input)": "Promise<SurvivalEntry>"
    }
    GetSurvivalLeaderboardUseCase: "GetSurvivalLeaderboardUseCase   <<Use Case>>" {
      shape: class
      "-survivalRepository": ISurvivalRepository
      "+execute(input)": "Promise<SurvivalEntry[]>"
    }
    GenerateLevelUseCase: "GenerateLevelUseCase   <<Use Case>>   (sin repositorio)" {
      shape: class
      "-levelGenerator": ILevelGenerator
      "+execute(input)": "Promise<LevelData>"
    }
  }

  ports2: "Puertos tecnicos" {
    style: { fill: "#F8FAFF"; stroke: "#1D4ED8"; stroke-dash: 3 }

    IUseCase: "IUseCase<I,O>   <<interface>>" {
      shape: class
      "+execute(input)": "Promise<O>"
    }
    IPasswordHasher: "IPasswordHasher   <<interface>>" {
      shape: class
      "+hash(password)": "Promise<string>"
    }
    IPasswordVerifier: "IPasswordVerifier   <<interface>>" {
      shape: class
      "+verify(password, hash)": "Promise<boolean>"
    }
    ITokenService: "ITokenService   <<interface>>" {
      shape: class
      "+generateToken(userId, username)": string
      "+verifyToken(token)": TokenPayload
    }
    IIdGenerator: "IIdGenerator   <<interface>>" {
      shape: class
      "+generate()": string
    }
    ILogger: "ILogger   <<interface>>" {
      shape: class
      "+info / warn / error / debug": void
    }
    ILevelGenerator: "ILevelGenerator   <<interface>>" {
      shape: class
      "+generate(spec)": "Promise<LevelData>"
    }
  }
}

# =============================================================
#  CAPA 1 · MODELO DE DOMINIO
# =============================================================
capa1: "CAPA 1 · Modelo de Dominio" {
  style: { fill: "#FFFBEB"; stroke: "#D97706"; font-size: 24; bold: true }

  aggregates: "Aggregates" {
    style: { fill: "#FEF3C7"; stroke: "#B45309" }

    User: "User   <<Aggregate Root>>" {
      shape: class
      "+id": UserId
      "+username": Username
      "+email": Email
      "+passwordHash": PasswordHash
      "+createdAt": Date
    }
    PlayerProgress: "PlayerProgress   <<Aggregate Root>>" {
      shape: class
      "+userId": UserId
      "+completedLevels": "LevelId[]"
      "+bestScores": "LevelScore[]"
      "+currentLevelId": LevelId
      "+isLevelCompleted(levelId)": boolean
      "+getBestScore(levelId)": "Score?"
    }
    LevelDefinition: "LevelDefinition   <<Aggregate Root>>" {
      shape: class
      "+id": LevelId
      "+name": LevelName
      "+difficulty": Difficulty
      "+parMoves": "ParMoves?"
      "+data": LevelData
      "+cellCount()": number
      "+arrowCount()": number
    }
    LeaderboardEntry: "LeaderboardEntry   <<Aggregate Root>>" {
      shape: class
      "+userId": UserId
      "+username": Username
      "+levelId": LevelId
      "+score": Score
      "+moves": Moves
      "+timeSeconds": TimeSeconds
      "+rankedAt": Date
    }
    SurvivalEntry: "SurvivalEntry   <<Aggregate Root>>" {
      shape: class
      "+userId": UserId
      "+username": Username
      "+boardsSolved": BoardsSolved
      "+durationSeconds": Duration
      "+totalScore": "Score?"
      "+playedAt": Date
    }
  }

  repos: "Repository Ports" {
    style: { fill: "#FDE68A"; stroke: "#92400E"; stroke-dash: 3 }

    IUserRepository: "IUserRepository   <<Repository>>" {
      shape: class
      "+findById(id)": "Promise<User | null>"
      "+findByEmail(email)": "Promise<User | null>"
      "+findByUsername(u)": "Promise<User | null>"
      "+create(user)": "Promise<User>"
      "+update(user)": "Promise<User>"
    }
    IProgressRepository: "IProgressRepository   <<Repository>>" {
      shape: class
      "+getByUserId(userId)": "Promise<PlayerProgress | null>"
      "+save(progress)": "Promise<PlayerProgress>"
    }
    ILeaderboardRepository: "ILeaderboardRepository   <<Repository>>" {
      shape: class
      "+addEntry(entry)": "Promise<LeaderboardEntry>"
      "+getByLevel(levelId, limit)": "Promise<LeaderboardEntry[]>"
    }
    ILevelDefinitionRepository: "ILevelDefinitionRepository   <<Repository>>" {
      shape: class
      "+getAll()": "Promise<LevelDefinition[]>"
      "+getById(id)": "Promise<LevelDefinition | null>"
      "+save(level)": "Promise<LevelDefinition>"
    }
    ISurvivalRepository: "ISurvivalRepository   <<Repository>>" {
      shape: class
      "+addEntry(entry)": "Promise<SurvivalEntry>"
      "+getTop(durationSeconds, limit)": "Promise<SurvivalEntry[]>"
    }
    ILeaderboardStrategy: "ILeaderboardStrategy   <<Domain Service>>" {
      shape: class
      "+calculateRanking(entries, limit)": "LeaderboardEntry[]"
    }
  }

  vos: "Value Objects" {
    style: { fill: "#FEF9C3"; stroke: "#CA8A04" }

    UserId: "UserId   <<Value Object>>" {
      shape: class
      "+value": string
      "+create(raw)": UserId
      "+equals(o)": boolean
    }
    Email: "Email   <<Value Object>>" {
      shape: class
      "+value": string
      "+create(raw)": Email
      "+equals(o)": boolean
    }
    Username: "Username   <<Value Object>>" {
      shape: class
      "+value": string
      "+create(raw)": Username
      "+equals(o)": boolean
    }
    PasswordHash: "PasswordHash   <<Value Object>>" {
      shape: class
      "+value": string
      "+create(raw)": PasswordHash
      "+equals(o)": boolean
    }
    LevelId: "LevelId   <<Value Object>>" {
      shape: class
      "+value": string
      "+create(raw)": LevelId
      "+equals(o)": boolean
    }
    LevelName: "LevelName   <<Value Object>>" {
      shape: class
      "+value": string
      "+create(raw)": LevelName
      "+equals(o)": boolean
    }
    Difficulty: "Difficulty   <<Value Object>>" {
      shape: class
      "+value": "easy|medium|hard"
      "+create(raw)": Difficulty
      "+equals(o)": boolean
    }
    ParMoves: "ParMoves   <<Value Object>>" {
      shape: class
      "+value": "number (>0)"
      "+create(raw)": ParMoves
      "+equals(o)": boolean
    }
    Score: "Score   <<Value Object>>" {
      shape: class
      "+value": "number (>=0)"
      "+create(raw)": Score
      "+equals(o)": boolean
    }
    Moves: "Moves   <<Value Object>>" {
      shape: class
      "+value": "number (>=0)"
      "+create(raw)": Moves
      "+equals(o)": boolean
    }
    TimeSeconds: "TimeSeconds   <<Value Object>>" {
      shape: class
      "+value": "number (>=0)"
      "+create(raw)": TimeSeconds
      "+equals(o)": boolean
    }
    LevelScore: "LevelScore   <<Value Object>>" {
      shape: class
      "+levelId": LevelId
      "+score": Score
      "+create(levelId, score)": LevelScore
      "+equals(o)": boolean
    }
    BoardsSolved: "BoardsSolved   <<Value Object>>" {
      shape: class
      "+value": "number (>=0)"
      "+create(raw)": BoardsSolved
      "+equals(o)": boolean
    }
    Duration: "Duration   <<Value Object>>" {
      shape: class
      "+value": "number (>0) seg"
      "+create(raw)": Duration
      "+equals(o)": boolean
    }
  }

  tablero: "Tablero — Value Objects compuestos (mecanica A)" {
    grid-columns: 1
    grid-gap: 90
    style: { fill: "#FDE68A"; stroke: "#CA8A04" }

    arriba: "" {
      grid-columns: 2
      grid-gap: 150
      style: { fill: "#FDE68A"; stroke: "#FDE68A" }

      LevelData: "LevelData   <<Value Object>>" {
        shape: class
        "+cells": "Cell[]"
        "+arrows": "ArrowData[]"
        "+lives": "number?"
        "+timeLimitSeconds": "number?"
        "+create(props)": LevelData
        "+toPrimitives()": LevelDataProps
      }
      ArrowData: "ArrowData   <<type>>" {
        shape: class
        "+id": string
        "+path": "Cell[]"
        "+color": string
      }
    }
    Cell: "Cell   <<type>>" {
      shape: class
      "+tuple": "[number, number]"
    }
  }

  errors: "Domain Errors" {
    style: { fill: "#FEE2E2"; stroke: "#B91C1C" }

    DomainError: "DomainError   <<abstract>>" {
      shape: class
      "+statusCode": number
      "+message": string
    }
    ValidationError: "ValidationError" {
      shape: class
      "+statusCode": "422"
    }
    InvalidCredentialsError: "InvalidCredentialsError" {
      shape: class
      "+statusCode": "401"
    }
    EmailAlreadyRegisteredError: "EmailAlreadyRegisteredError" {
      shape: class
      "+statusCode": "409"
    }
    UsernameAlreadyTakenError: "UsernameAlreadyTakenError" {
      shape: class
      "+statusCode": "409"
    }
    NotFoundError: "NotFoundError" {
      shape: class
      "+statusCode": "404"
    }
    LevelGenerationError: "LevelGenerationError" {
      shape: class
      "+statusCode": "502"
    }
  }
}

# =============================================================
#  ORDEN DE CAPAS (aristas invisibles: fijan el apilado C4->C3->C2->C1)
# =============================================================
capa4 -> capa3: { style.opacity: 0 }
capa3 -> capa2: { style.opacity: 0 }
capa2 -> capa1: { style.opacity: 0 }

# Dentro de C1: empujar repos y errors DEBAJO de agregados+VOs, para que
# la composicion (agregado -> VO) quede corta y no cruce los repositorios.
capa1.aggregates -> capa1.repos: { style.opacity: 0 }
capa1.vos -> capa1.repos: { style.opacity: 0 }
capa1.vos -> capa1.errors: { style.opacity: 0 }

# =============================================================
#  REALIZACION  (implements) — triangulo hueco + punteada
# =============================================================
capa4.repositories.PostgresUserRepository -> capa1.repos.IUserRepository: { target-arrowhead: { shape: triangle; style.filled: false }; style.stroke-dash: 4; style.stroke: "#15803D" }
capa4.repositories.PostgresProgressRepository -> capa1.repos.IProgressRepository: { target-arrowhead: { shape: triangle; style.filled: false }; style.stroke-dash: 4; style.stroke: "#15803D" }
capa4.repositories.PostgresLeaderboardRepository -> capa1.repos.ILeaderboardRepository: { target-arrowhead: { shape: triangle; style.filled: false }; style.stroke-dash: 4; style.stroke: "#15803D" }
capa4.repositories.PostgresLevelDefinitionRepository -> capa1.repos.ILevelDefinitionRepository: { target-arrowhead: { shape: triangle; style.filled: false }; style.stroke-dash: 4; style.stroke: "#15803D" }
capa4.repositories.PostgresSurvivalRepository -> capa1.repos.ISurvivalRepository: { target-arrowhead: { shape: triangle; style.filled: false }; style.stroke-dash: 4; style.stroke: "#15803D" }

capa4.strategies.PerLevel -> capa1.repos.ILeaderboardStrategy: { target-arrowhead: { shape: triangle; style.filled: false }; style.stroke-dash: 4; style.stroke: "#6D28D9" }
capa4.strategies.TotalScore -> capa1.repos.ILeaderboardStrategy: { target-arrowhead: { shape: triangle; style.filled: false }; style.stroke-dash: 4; style.stroke: "#6D28D9" }
capa4.strategies.Combined -> capa1.repos.ILeaderboardStrategy: { target-arrowhead: { shape: triangle; style.filled: false }; style.stroke-dash: 4; style.stroke: "#6D28D9" }

capa4.services.Bcrypt -> capa2.ports2.IPasswordHasher: { target-arrowhead: { shape: triangle; style.filled: false }; style.stroke-dash: 4; style.stroke: "#4B5563" }
capa4.services.Bcrypt -> capa2.ports2.IPasswordVerifier: { target-arrowhead: { shape: triangle; style.filled: false }; style.stroke-dash: 4; style.stroke: "#4B5563" }
capa4.services.Uuid -> capa2.ports2.IIdGenerator: { target-arrowhead: { shape: triangle; style.filled: false }; style.stroke-dash: 4; style.stroke: "#4B5563" }
capa4.services.AuthFacade -> capa2.ports2.ITokenService: { target-arrowhead: { shape: triangle; style.filled: false }; style.stroke-dash: 4; style.stroke: "#4B5563" }
